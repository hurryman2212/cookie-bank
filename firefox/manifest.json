{
  "manifest_version": 2,
  "name": "Cookie Bank",
  "version": "0.1.0",
  "description": "Writes brokered cookie updates into this browser profile.",
  "icons": {
    "128": "icons/icon-1024.png"
  },
  "permissions": [
    "cookies",
    "nativeMessaging",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "Cookie Bank",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "cookie-bank@local",
      "strict_min_version": "109.0"
    }
  }
}